{
  "name": "brewbrain",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "analyze": "cross-env ANALYZE=true npm run build",
    "bundle:report": "node scripts/generate-bundle-report.mjs",
    "analyze:report": "npm run analyze && npm run bundle:report",
    "start": "next start",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --fix",
    "lint:audit": "eslint . --ext .ts,.tsx,.js,.jsx -f json --fix-dry-run > eslint-fix-report.json",
    "lint:audit:summary": "node scripts/summarize-eslint-fix-report.mjs eslint-fix-report.json eslint-fix-summary.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:components": "vitest run __tests__/components",
    "verify:env": "node scripts/verify-required-env.mjs --profile=build",
    "verify:env:server": "node scripts/verify-required-env.mjs --profile=server",
    "verify:env:smoke": "node scripts/verify-required-env.mjs --profile=smoke",
    "verify:env:migrations": "node scripts/verify-required-env.mjs --profile=migrations",
    "db:migrate:ordered": "node scripts/apply-ordered-migrations.mjs",
    "verify:sw-precache": "node scripts/check-sw-precache.mjs",
    "test:offline-precache": "PLAYWRIGHT_SERVER_COMMAND='npm run start -- -p 3005' PLAYWRIGHT_SERVER_URL='http://localhost:3005' playwright test playwright/offline-precache.spec.ts --reporter=line",
    "test:offline-queue": "ENABLE_BENCHMARK_ROUTES='1' PLAYWRIGHT_SERVER_COMMAND='npm run start -- -p 3005' PLAYWRIGHT_SERVER_URL='http://127.0.0.1:3005/benchmarks/offline-sync' PLAYWRIGHT_BASE_URL='http://127.0.0.1:3005' playwright test playwright/offline-queue.e2e.spec.ts --project=chromium --reporter=line",
    "e2e:smoke:local": "ENABLE_BENCHMARK_ROUTES='1' PLAYWRIGHT_SERVER_COMMAND='npm run start -- -p 3005' PLAYWRIGHT_SERVER_URL='http://127.0.0.1:3005/login' PLAYWRIGHT_BASE_URL='http://127.0.0.1:3005' playwright test playwright/ci/smoke.spec.ts --project=chromium --reporter=line",
    "test:a11y": "ENABLE_BENCHMARK_ROUTES='1' PLAYWRIGHT_SERVER_COMMAND='npm run start -- -p 3005' PLAYWRIGHT_SERVER_URL='http://127.0.0.1:3005/login' PLAYWRIGHT_BASE_URL='http://127.0.0.1:3005' playwright test playwright/a11y --project=chromium --reporter=line",
    "benchmark:virtualization": "playwright test playwright/virtualization.benchmark.spec.ts --reporter=line",
    "scan:secrets": "node scripts/run-secrets-scan.mjs",
    "scan:secrets:staged": "node scripts/run-secrets-scan.mjs --staged",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@google/generative-ai": "^0.24.1",
    "@sentry/nextjs": "^10.47.0",
    "@serwist/next": "^9.5.7",
    "@serwist/sw": "^9.5.7",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.0",
    "@tanstack/react-virtual": "^3.13.23",
    "@yudiel/react-qr-scanner": "^2.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.38.0",
    "idb-keyval": "^6.2.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.3",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "shadcn": "^4.1.1",
    "sonner": "^2.0.7",
    "stripe": "^21.0.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@next/bundle-analyzer": "^16.2.2",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-bluetooth": "^0.0.21",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.3",
    "axe-core": "^4.11.0",
    "cross-env": "^10.1.0",
    "date-fns": "^4.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
