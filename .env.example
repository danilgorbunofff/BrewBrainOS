# Copy this file to .env.local for local development.
# Do not commit real server secrets. Keep them in GitHub Secrets or your deployment vault.

# Public browser-safe configuration (required for app startup and production builds)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public browser monitoring (optional)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# Public web push key (optional unless push notifications are enabled)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=replace-with-vapid-public-key

# Server-only required for service-role, cron, and billing flows
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
STRIPE_SECRET_KEY=sk_test_replace_me
CRON_SECRET=replace-with-random-hex

# Server-only optional integrations
STRIPE_WEBHOOK_SECRET=whsec_replace_me
GEMINI_API_KEY=replace-with-gemini-api-key
SENTRY_DSN=
SENTRY_ENV=development
SENTRY_TRACES_SAMPLE_RATE=0.1
VAPID_SUBJECT=mailto:security@example.com
VAPID_PRIVATE_KEY=replace-with-vapid-private-key

# Stripe product and pricing IDs (optional until paid tiers are configured)
STRIPE_PRICE_NANO=
STRIPE_PRICE_PRODUCTION=
STRIPE_PRICE_MULTI_SITE=
STRIPE_PRICE_WHITE_GLOVE=

# Feature flags and monitoring
ENABLE_BENCHMARK_ROUTES=0
ENABLE_PERF_MONITORING=0
NEXT_PUBLIC_ENABLE_PERF_MONITORING=0
NEXT_PUBLIC_PERF_CONSOLE_LOGGING=0
NEXT_PUBLIC_PERFORMANCE_ENDPOINT=/api/monitoring/performance

# Playwright and local QA
E2E_TEST_USER_EMAIL=
E2E_TEST_USER_PASSWORD=
PLAYWRIGHT_A11Y_USE_FIXTURES=0
PLAYWRIGHT_SERVER_COMMAND=
PLAYWRIGHT_SERVER_URL=
PLAYWRIGHT_BASE_URL=
PLAYWRIGHT_USE_EXISTING_SERVER=false
PLAYWRIGHT_REUSE_EXISTING_SERVER=

# Ordered migrations
# The local migration script reads SUPABASE_DB_URL.
# GitHub Actions uses the secret name SUPABASE_MIGRATION_DB_URL and maps it to SUPABASE_DB_URL.
SUPABASE_DB_URL=

# CI-only optional secrets and variables
SUPABASE_MIGRATION_DB_URL=
SENTRY_AUTH_TOKEN=