# Public application configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only credentials
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
GEMINI_API_KEY=replace-me
CRON_SECRET=replace-with-random-hex
SENTRY_DSN=
SENTRY_ENV=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Browser error reporting
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# Stripe product and pricing IDs
STRIPE_PRICE_NANO=
STRIPE_PRICE_PRODUCTION=
STRIPE_PRICE_MULTI_SITE=
STRIPE_PRICE_WHITE_GLOVE=

# Push notifications
VAPID_SUBJECT=mailto:security@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=replace-with-vapid-public-key
VAPID_PRIVATE_KEY=replace-with-vapid-private-key

# Feature flags and monitoring
ENABLE_BENCHMARK_ROUTES=0
ENABLE_PERF_MONITORING=0
NEXT_PUBLIC_ENABLE_PERF_MONITORING=0
NEXT_PUBLIC_PERF_CONSOLE_LOGGING=0
NEXT_PUBLIC_PERFORMANCE_ENDPOINT=/api/monitoring/performance

# Playwright smoke test account
E2E_TEST_USER_EMAIL=
E2E_TEST_USER_PASSWORD=